# ============================================================
# SYNTHETIC TEST FILE - best_practice_01.env
# This file follows security best practices.
# All sensitive values use environment variable references.
# Expected result: ZERO issues detected.
# ============================================================

# --- Application Settings ---
APP_NAME=MyWebApp
APP_ENV=production
DEBUG=false
PORT=8080

# --- Database (all via env vars) ---
DATABASE_PASSWORD=${DATABASE_PASSWORD}
DATABASE_URL=${DATABASE_URL}
DB_USER=${DB_USER}
DB_HOST=${DB_HOST}

# --- API Keys (env var references only) ---
STRIPE_API_KEY=${STRIPE_API_KEY}
GITHUB_TOKEN=${GITHUB_TOKEN}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}

# --- Security Settings ---
SECRET_KEY=${SECRET_KEY}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
ENCRYPTION_ALGORITHM=AES-256-GCM

# --- TLS / Network ---
SSL_VERIFY=true
TLS_MIN_VERSION=TLSv1.3

# --- Access Control ---
CORS_ORIGINS=${CORS_ALLOWED_ORIGINS}
ALLOWED_HOSTS=${ALLOWED_HOSTS}

# --- Logging ---
LOG_LEVEL=INFO
LOGGING_ENABLED=true
LOG_PASSWORDS=false

# --- Session ---
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
