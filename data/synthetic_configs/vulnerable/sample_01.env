# ============================================================
# SYNTHETIC TEST FILE - sample_01.env
# WARNING: This file contains INTENTIONAL security issues
#          for testing the SecConfig Analyzer rule engine.
#          None of these are real credentials.
# ============================================================

# --- Application Settings ---
APP_NAME=MyWebApp
APP_ENV=development
DEBUG=true
PORT=8080

# --- CRED-001: Hard-coded Password ---
DATABASE_PASSWORD=admin123

# --- CRED-002: Exposed API Key ---
STRIPE_API_KEY=sk_live_abcdef1234567890abcdef12

# --- CRED-003: Hard-coded DB Connection String ---
DATABASE_URL=postgres://admin:password@db.example.com:5432/mydb

# --- CRED-004: Weak Secret Key ---
SECRET_KEY=mysecret

# --- CRED-005: Hard-coded Token ---
GITHUB_TOKEN=ghp_abcdefghijklmnopqrstuvwxyz123456

# --- ENC-001: Weak Encryption Algorithm ---
ENCRYPTION_ALGORITHM=MD5

# --- ENC-002: TLS Verification Disabled ---
SSL_VERIFY=false

# --- ENC-003: Weak TLS Version ---
TLS_MIN_VERSION=TLSv1.0

# --- AC-001: Permissive CORS ---
CORS_ORIGINS=*

# --- AC-002: Unrestricted Allowed Hosts ---
ALLOWED_HOSTS=*

# --- LOG-001: Logging Disabled ---
LOG_LEVEL=none

# --- LOG-002: Sensitive Data Logging ---
LOG_PASSWORDS=true

# --- BASE-001: Debug Mode On ---
FLASK_DEBUG=true

# --- BASE-002: Development Environment ---
APP_ENV=development
