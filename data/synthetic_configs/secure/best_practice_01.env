# Application Configuration - SECURE BEST PRACTICE 01
# All sensitive values use environment variable references

# ===== CREDENTIALS (all use env var references) =====
DATABASE_PASSWORD=${DATABASE_PASSWORD}
DB_USERNAME=${DB_USERNAME}
API_KEY=${API_KEY}
SECRET_KEY=${SECRET_KEY}
ADMIN_PASSWORD=${ADMIN_PASSWORD}

# ===== ENCRYPTION (strong algorithms) =====
CIPHER_ALGORITHM=AES-256-GCM
SSL_VERSION=TLSv1.3
SSL_VERIFY=true
HASH_ALGORITHM=SHA-256

# ===== ACCESS CONTROL =====
CORS_ORIGIN=${ALLOWED_ORIGINS}
DEBUG=false
ADMIN_HOST=127.0.0.1

# ===== LOGGING =====
LOGGING_ENABLED=true
LOG_LEVEL=WARNING
LOG_FILE=/var/log/app/application.log

# ===== BASELINE =====
TESTING=false
SESSION_TIMEOUT=1800
SECURE=true
ALLOWED_HOSTS=${ALLOWED_HOSTS}

# ===== OTHER SETTINGS =====
APP_NAME=MyApplication
APP_PORT=8080
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=myapp_db
