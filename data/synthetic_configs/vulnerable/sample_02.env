# E-Commerce Application Config - VULNERABLE SAMPLE 02
# Focuses on encryption and access control issues

# ===== DATABASE =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=admin
DB_PASSWORD=shop2024

# ===== PAYMENT GATEWAY =====
STRIPE_SECRET_KEY=sk_live_abcdefghijklmnopqrstuvwx
PAYPAL_CLIENT_SECRET=paypal_secret_xyz_123456
PAYMENT_ENCRYPTION_KEY=hardcodedpaymentkey9876

# ===== ENCRYPTION =====
HASH_ALGORITHM=MD5
TLS_MIN_VERSION=TLSv1.0
